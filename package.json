{
  "name": "weave-client",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && tsc -p tsconfig.electron.json && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "lefthook install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "electron": "^41.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
